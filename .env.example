# Shopify Admin API — SERVER-SIDE ONLY (never prefix with NEXT_PUBLIC_)
#
# Setup: Shopify admin → Settings → Apps → Develop apps → Create an app.
#   Admin API scopes: read_orders (required), read_customers (optional, for customer name).
#   Install the app, then copy the Admin API access token (starts with shpat_).
#
# Add these in Vercel → Settings → Environment Variables (Production/Preview/Development),
# and copy this file to `.env.local` for local development.

SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2026-04
